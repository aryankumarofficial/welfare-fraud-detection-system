# PostgreSQL (shared by Fastify, Next.js, FastAPI, and workers)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/welfare

# Optional connection pool tuning
DB_POOL_MAX=10
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# Redis (future queue/cache usage)
REDIS_URL=redis://localhost:6379

# BullMQ prediction processing
PREDICTION_QUEUE_NAME=prediction-processing
PREDICTION_QUEUE_API_URL=http://localhost:8010
PREDICTION_QUEUE_API_PORT=8010
PREDICTION_WORKER_CONCURRENCY=2
ML_SERVICE_URL=http://localhost:8000
