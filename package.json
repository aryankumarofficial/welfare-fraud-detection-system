{
  "name": "welfare-fraud-detection-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "setup": "bun install && bun run setup:ml",
    "setup:ml": "cd services/ml && python -m venv venv && venv/Scripts/pip install -r requirements.txt",
    "import:csv": "bun run scripts/import-csv.ts",
    "dev": "bun run --filter=admin dev",
    "api": "bun run --filter=api dev",
    "ml": "bun --filter @repo/ml-service dev",
    "prediction:queue": "bun --filter @repo/workers prediction:queue",
    "prediction:worker": "bun --filter @repo/workers prediction:worker",
    "prediction:events": "bun --filter @repo/workers prediction:events",
    "db:generate": "bun run --filter @repo/db db:generate",
    "db:migrate": "bun run --filter @repo/db db:migrate",
    "db:push": "bun run --filter @repo/db db:push",
    "db:studio": "bun run --filter @repo/db db:studio",
    "db:check": "bun run --filter @repo/db db:check",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "dev:all": "bun run api & bun run dev & bun run ml"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
